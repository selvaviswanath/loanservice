# Copy this to .env and fill in real values.
# Never commit .env to git.

# PostgreSQL connection
DB_URL=jdbc:postgresql://localhost:5432/loandb
DB_USERNAME=loanuser
DB_PASSWORD=loanpass123

# JWT — generate a strong secret (min 32 chars):
#   openssl rand -hex 32
JWT_SECRET=replace-this-with-a-secure-random-secret-min-32-chars
JWT_EXPIRATION_MS=86400000
